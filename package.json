{
  "name": "@capgo/capacitor-uwb",
  "version": "8.0.0",
  "description": "Capacitor plugin for Ultra-Wideband (UWB) ranging on iOS and Android.",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Sources",
    "ios/Tests",
    "Package.swift",
    "CapgoCapacitorUwb.podspec"
  ],
  "author": "Martin Donadieu <martin@capgo.app>",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cap-go/capacitor-uwb.git"
  },
  "bugs": {
    "url": "https://github.com/Cap-go/capacitor-uwb/issues"
  },
  "homepage": "https://github.com/Cap-go/capacitor-uwb",
  "keywords": [
    "capacitor",
    "uwb",
    "ultra-wideband",
    "nearby-interaction",
    "ranging"
  ],
  "scripts": {
    "verify": "bun run verify:ios && bun run verify:android && bun run verify:web",
    "verify:ios": "xcodebuild -scheme CapgoCapacitorCapacitorUwb -destination generic/platform=iOS",
    "verify:ios": "xcodebuild -scheme CapgoCapacitorUwb -destination generic/platform=iOS",
    "verify:web": "bun run build",
    "lint": "bun run eslint && bun run prettier -- --check && bun run swiftlint -- lint",
    "fmt": "bun run eslint -- --fix && bun run prettier -- --write && bun run swiftlint -- --fix --format",
    "eslint": "eslint \"**/*.ts\"",
    "prettier": "prettier-pretty-check \"**/*.{css,html,ts,js,java}\" --plugin=prettier-plugin-java",
    "swiftlint": "node-swiftlint",
    "docgen": "docgen --api CapacitorUwbPlugin --output-readme README.md --output-json dist/docs.json",
    "build": "bun run clean && bun run docgen && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "bun run build",
    "check:wiring": "node scripts/check-capacitor-plugin-wiring.mjs",
    "example:install": "cd example-app && bun install --frozen-lockfile",
    "example:build": "bun run build && cd example-app && bun install --frozen-lockfile && bun run build"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/docgen": "^0.3.1",
    "@capacitor/ios": "^8.3.4",
    "@eslint/js": "^10.0.1",
    "@ionic/prettier-config": "^4.0.0",
    "@ionic/swiftlint-config": "^2.0.0",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "prettier-plugin-java": "^2.9.2",
    "prettier-pretty-check": "^0.2.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.4",
    "swiftlint": "^2.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "peerDependencies": {
    "@capacitor/core": ">=8.0.0"
  },
  "prettier": "@ionic/prettier-config",
  "swiftlint": "@ionic/swiftlint-config",
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
